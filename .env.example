#Обязательные значения(заменить на свои)

# Токен Telegram-бота получить в телеграмм-боте @BotFather
TELEGRAM_BOT_TOKEN=токен_от_BotFather_сюда
# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=ваш_ключ_сюда

# Значения по умолчанию

# Если менять модель, то ОБЯЗАТЕЛЬНО с поддержкой инструментов (tools).
# Бесплатные с tools ищем на openrouter.ai/models (фильтры Tools + Free).
MODEL=https://openrouter.ai/api/v1
# Базовый URL OpenRouter (менять не нужно)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Лимит размера файла, МБ (Bot API ограничивает скачивание ~20 МБ)
MAX_FILE_MB=20
# Максимальная длина пользовательской инструкции, символов
MAX_INSTRUCTION_CHARS=2000
# Таймаут одного выполнения кода в песочнице, сек
EXEC_TIMEOUT_SEC=45
# Лимит памяти на один запуск кода, МБ
MEM_LIMIT_MB=2048
# Максимум шагов агента (вызовов кода) на один анализ
MAX_AGENT_ITERS=14
# Сколько анализов выполнять параллельно
MAX_CONCURRENT=3
